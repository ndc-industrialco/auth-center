DATABASE_URL="postgresql://user:password@host:5432/auth-center?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/auth-center?schema=public"

NODE_ENV=production
NEXTAUTH_URL=https://auth.ndcindustrial.co.th
AUTH_URL=https://auth.ndcindustrial.co.th
AUTH_TRUST_HOST=true
AUTH_SECRET=replace-with-long-random-secret

REDIS_URL="redis://localhost:6379"

# Production token signing
AUTH_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-pkcs8-private-key\n-----END PRIVATE KEY-----"
AUTH_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nreplace-with-spki-public-key\n-----END PUBLIC KEY-----"
AUTH_KEY_ID="replace-with-key-id"

# Microsoft Entra ID
AZURE_AD_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_AD_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_AD_CLIENT_SECRET=replace-with-entra-client-secret

# Optional seed helper
SEED_EMPLOYEE_ID=EMP001
SEED_PASSWORD=ChangeMe123!
SEED_DISPLAY_NAME="NDC Admin"
